Algoritmo Area_Triangulo
    Definir base, altura, area Como Real
    
    Escribir "Calculadora de ·rea de tri·ngulo"
    Escribir "Ingrese la base:"
    Leer base
    Escribir "Ingrese la altura:"
    Leer altura
    
    area <- base * altura / 2
    
    Escribir "El ·rea del tri·ngulo es: ", area
FinAlgoritmo